name: Build and Deploy Docs

on:
  push:
    branches:
      - main
  workflow_dispatch:

permissions:
  contents: read
  pages: write
  id-token: write

jobs:
  build_docs:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Install Lean
        uses: leanprover/lean-action@v1
        with:
          auto-config: false # We will handle the config steps manually below
          use-mathlib-cache: false # We will run cache get manually after update

      - name: Generate Manifest and Get Cache
        run: |
          lake update
          lake exe cache get

      - name: Build project API documentation
        run: lake -R -Kenv=dev build Siat:docs

      - name: Upload website
        uses: actions/upload-pages-artifact@v3
        with:
          path: .lake/build/doc

      - name: Deploy to GitHub Pages
        id: deployment
        uses: actions/deploy-pages@v4

